# =====================================================================
# e-commerce-backend environment template
# Copy this file to .env and fill in real values. NEVER commit .env.
# =====================================================================

# --- Django ---
DEBUG=1
SECRET_KEY=replace-me-with-a-long-random-string
ALLOWED_HOSTS=localhost 127.0.0.1

# --- Database (Postgres + pgvector) ---
DB_NAME=ecommerce_db
DB_USER=postgres
DB_PASS=change-me-strong-password
DB_HOST=postgresql
DB_PORT=5432

# Used by the Postgres container itself
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Used to bootstrap the secondary Keycloak DB (kept for compatibility)
KEYCLOAK_DB_NAME=keycloak_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (SimpleJWT) ---
# Optional. Falls back to SECRET_KEY if unset. Set this in production so
# rotating the Django SECRET_KEY doesn't simultaneously invalidate every
# outstanding access/refresh token.
JWT_SIGNING_KEY=

# --- Keycloak (DISABLED for MVP — see BUILD_PLAN.md / Run log 2026-05-21) ---
# Block left in template so re-enabling Keycloak later is just an
# uncomment + service-add. Values are not read while SimpleJWT is active.
# KEYCLOAK_SERVER_URL=http://keycloak:8083/
# KEYCLOAK_REALM=master
# KEYCLOAK_CLIENT_ID=ecommerce-backend
# KEYCLOAK_CLIENT_SECRET=change-me-keycloak-secret

# --- Cloudinary (product image hosting) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Replicate (CLIP embeddings + hair try-on) ---
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- M-Pesa Daraja (Phase 1+) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox
